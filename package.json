{
  "name": "nuxt-ssr-telemetry",
  "version": "0.1.0",
  "description": "A Nuxt 3 module to inject request IDs and structured Pino logging for SSR.",
  "author": "Jean Everton <jeanever39@gmail.com>",
  "repository": "github:jeaneverton/nuxt-ssr-telemetry",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "playground"
  ],
  "keywords": [
    "nuxt",
    "pino",
    "telemetry",
    "logging",
    "ssr",
    "correlation",
    "request-id",
    "traceability"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.8",
    "defu": "^6.1.4",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@nuxt/cli": "^3.37.0",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.8",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "latest",
    "@types/pino": "^7.0.4",
    "changelogen": "^0.6.2",
    "eslint": "^10.4.1",
    "nuxt": "^4.4.8",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.3"
  }
}
